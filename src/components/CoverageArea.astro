---
import { locations } from '../config/locations';
import LocationCard from './LocationCard.astro';
---

<section class="section-padding">
  <div class="container-narrow mx-auto">
    <h2 class="text-center text-3xl font-bold text-accent">Areas We Cover</h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-gray-600">Professional drain services across Swindon and the surrounding Wiltshire area.</p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {locations.map(l => (
        <LocationCard location={l} />
      ))}
    </div>
  </div>
</section>
