---
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<div class="space-y-3">
  {faqs.map((faq) => (
    <details class="group rounded-xl border border-gray-200 bg-white">
      <summary class="flex cursor-pointer items-center justify-between p-5 font-medium text-accent hover:text-primary transition-colors">
        <span>{faq.question}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </summary>
      <div class="border-t px-5 pb-5 pt-3 text-gray-600">
        <Fragment set:html={faq.answer} />
      </div>
    </details>
  ))}
</div>
