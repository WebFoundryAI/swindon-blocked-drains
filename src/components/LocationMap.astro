---
interface Props {
  lat: number;
  lng: number;
  locationName: string;
  zoom?: number;
}

const { lat, lng, locationName, zoom = 14 } = Astro.props;
const query = encodeURIComponent(`${locationName}`);
const embedUrl = `https://www.google.com/maps?q=${query}&z=${zoom}&output=embed`;
---

<div class="rounded-xl overflow-hidden shadow-sm border border-border h-[300px] md:h-[400px]">
  <iframe
    src={embedUrl}
    title={`Map showing ${locationName}`}
    width="100%"
    height="100%"
    style="border:0;"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  allow="fullscreen"
  ></iframe>
</div>
