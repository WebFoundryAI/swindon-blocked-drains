---
interface Props {
  items: { name: string; url: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="bg-gray-50 border-b">
  <div class="container-narrow mx-auto px-4 py-3">
    <ol class="flex flex-wrap items-center gap-1 text-sm text-gray-500">
      <li>
        <a href="/" class="hover:text-primary transition-colors">Home</a>
      </li>
      {items.map((item, i) => (
        <li class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
          {i === items.length - 1 ? (
            <span class="font-medium text-accent" aria-current="page">{item.name}</span>
          ) : (
            <a href={item.url} class="hover:text-primary transition-colors">{item.name}</a>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
