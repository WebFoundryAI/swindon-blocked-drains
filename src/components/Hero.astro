---
import { brand } from '../config/brand';

interface Props {
  title: string;
  subtitle?: string;
  showCta?: boolean;
  compact?: boolean;
}

const { title, subtitle, showCta = true, compact = false } = Astro.props;
---

<section class={`relative ${compact ? 'py-16 lg:py-20' : 'py-24 lg:py-36'} bg-accent overflow-hidden`}>
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/images/hero-bg.webp" alt="" class="h-full w-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-accent/90 via-accent/80 to-accent/60"></div>
  </div>

  <div class="container-narrow relative mx-auto px-4 text-center text-white">
    <h1 class={`font-bold leading-tight ${compact ? 'text-3xl lg:text-4xl' : 'text-4xl lg:text-5xl xl:text-6xl'}`}>
      {title}
    </h1>

    {subtitle && (
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-200 lg:text-xl">
        {subtitle}
      </p>
    )}

    {showCta && (
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={brand.phoneHref} class="btn-cta">
          <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          Call {brand.phone}
        </a>
        <a href="/contact/" class="btn-primary bg-white/10 border border-white/30 hover:bg-white/20">
          Get a Free Quote
        </a>
      </div>
    )}
  </div>
</section>
