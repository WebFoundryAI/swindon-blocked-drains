---
import { brand } from '../config/brand';
import { services } from '../config/services';

interface Props {
  schemas?: object[];
  breadcrumbs?: { name: string; url: string }[];
}

const { schemas = [], breadcrumbs = [] } = Astro.props;

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Plumber',
  '@id': `${brand.url}/#organization`,
  name: brand.name,
  telephone: brand.phone,
  email: brand.email,
  url: brand.url,
  image: `${brand.url}/images/hero-bg.webp`,
  logo: `${brand.url}/favicon.png`,
  priceRange: '££',
  areaServed: [
    {
      '@type': 'City',
      name: 'Swindon',
      containedInPlace: { '@type': 'AdministrativeArea', name: 'Wiltshire' },
    },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Swindon',
    addressRegion: 'Wiltshire',
    addressCountry: 'GB',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
};

const serviceSchemas = services.map(s => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.name,
  description: s.description,
  url: `${brand.url}/services/${s.slug}/`,
  provider: { '@type': 'Plumber', '@id': `${brand.url}/#organization` },
  areaServed: { '@type': 'City', name: 'Swindon' },
  availableChannel: {
    '@type': 'ServiceChannel',
    servicePhone: { '@type': 'ContactPoint', telephone: brand.phone },
  },
}));

const breadcrumbSchema = breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: brand.url },
    ...breadcrumbs.map((bc, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: bc.name,
      item: `${brand.url}${bc.url}`,
    })),
  ],
} : null;

const allSchemas = [localBusiness, ...serviceSchemas, ...(breadcrumbSchema ? [breadcrumbSchema] : []), ...schemas];
---

{allSchemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
