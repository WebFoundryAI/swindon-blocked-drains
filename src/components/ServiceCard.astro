---
import type { Service } from '../config/services';

interface Props {
  service: Service;
  locationSlug?: string;
}

const { service, locationSlug } = Astro.props;
const href = locationSlug
  ? `/locations/${locationSlug}/${service.slug}/`
  : `/services/${service.slug}/`;
---

<a href={href} class="group block rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-primary hover:shadow-md">
  <span class="text-4xl" role="img" aria-hidden="true">{service.icon}</span>
  <h3 class="mt-3 text-xl font-semibold text-accent group-hover:text-primary transition-colors">{service.name}</h3>
  <p class="mt-2 text-sm text-gray-600">{service.description}</p>
  <span class="mt-4 inline-flex items-center text-sm font-medium text-primary group-hover:underline">
    Learn more
    <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
  </span>
</a>
