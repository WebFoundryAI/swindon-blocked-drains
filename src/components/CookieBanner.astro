---

<div id="cookie-banner" class="fixed bottom-16 left-4 right-4 z-40 hidden rounded-xl bg-white p-4 shadow-2xl border sm:bottom-4 sm:left-auto sm:right-4 sm:max-w-md" role="dialog" aria-label="Cookie consent">
  <p class="text-sm text-gray-700">
    We use cookies to improve your experience. By continuing to browse, you agree to our
    <a href="/cookies/" class="text-primary underline">cookie policy</a>.
  </p>
  <div class="mt-3 flex gap-2">
    <button id="accept-cookies" class="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-dark transition-colors">Accept</button>
    <button id="reject-cookies" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Reject</button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const accept = document.getElementById('accept-cookies');
  const reject = document.getElementById('reject-cookies');

  if (!localStorage.getItem('cookies-consent')) {
    banner?.classList.remove('hidden');
  }

  accept?.addEventListener('click', () => {
    localStorage.setItem('cookies-consent', 'accepted');
    banner?.classList.add('hidden');
    if (typeof window.loadGA === 'function') window.loadGA();
  });

  reject?.addEventListener('click', () => {
    localStorage.setItem('cookies-consent', 'rejected');
    banner?.classList.add('hidden');
    window['ga-disable-' + window.__gaId] = true;
  });
</script>
