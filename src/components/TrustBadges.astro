---
const badges = [
  { icon: '🕐', title: '24/7 Available', desc: 'Day or night, we\'re here' },
  { icon: '🛡️', title: 'Fully Insured', desc: 'Complete peace of mind' },
  { icon: '📍', title: 'Local Engineers', desc: 'Based in Swindon' },
  { icon: '✅', title: 'No Call-Out Charge', desc: 'Free estimates' },
];
---

<section class="bg-gray-50 py-8">
  <div class="container-narrow mx-auto px-4">
    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
      {badges.map(badge => (
        <div class="flex items-center gap-3 rounded-lg bg-white p-4 shadow-sm">
          <span class="text-3xl" role="img" aria-hidden="true">{badge.icon}</span>
          <div>
            <p class="font-semibold text-accent">{badge.title}</p>
            <p class="text-sm text-gray-500">{badge.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
