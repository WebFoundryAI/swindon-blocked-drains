---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import LeadForm from '../../../components/LeadForm.astro';
import { brand } from '../../../config/brand';
import { services } from '../../../config/services';
import { locations } from '../../../config/locations';
import { subServiceTitle, subServiceDescription } from '../../../config/seo';
import contentData from '../../../data/ai-content.json';
const content = contentData as Record<string, string>;

export function getStaticPaths() {
  return services.flatMap(s =>
    s.subServices.map(sub => ({
      params: { service: s.slug, subservice: sub.slug },
      props: { service: s, subService: sub },
    }))
  );
}

const { service, subService } = Astro.props;
const pageContent = content[`subService:${service.slug}:${subService.slug}`] || '';
const breadcrumbs = [
  { name: 'Services', url: '/services/' },
  { name: service.name, url: `/services/${service.slug}/` },
  { name: subService.name, url: `/services/${service.slug}/${subService.slug}/` },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${subService.name} Swindon`,
  description: `Professional ${subService.name.toLowerCase()} services in Swindon from ${brand.name}.`,
  provider: {
    '@type': 'Plumber',
    name: brand.name,
    telephone: brand.phone,
  },
};
---

<BaseLayout
  title={subServiceTitle(service, subService)}
  description={subServiceDescription(service, subService)}
  breadcrumbs={breadcrumbs}
  schemas={[serviceSchema]}
>
  <Breadcrumbs items={breadcrumbs} />
  <Hero title={`${subService.name} in Swindon`} subtitle={`Expert ${subService.name.toLowerCase()} services as part of our ${service.name.toLowerCase()} solutions`} compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid gap-12 lg:grid-cols-3">
        <div class="lg:col-span-2">
          {pageContent && (
            <div class="prose prose-lg max-w-none text-gray-700">
              <Fragment set:html={pageContent} />
            </div>
          )}

          <!-- Available in locations -->
          <div class="mt-12">
            <h2 class="text-2xl font-bold text-accent">{subService.name} Near You</h2>
            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              {locations.map(l => (
                <a href={`/locations/${l.slug}/${service.slug}/${subService.slug}/`} class="rounded-lg border border-gray-200 p-4 hover:border-primary hover:shadow-sm transition-all">
                  <span class="font-medium text-accent">{subService.name} in {l.name}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Other sub-services -->
          <div class="mt-12">
            <h2 class="text-2xl font-bold text-accent">Other {service.name} Services</h2>
            <div class="mt-4 flex flex-wrap gap-3">
              {service.subServices.filter(s => s.slug !== subService.slug).map(s => (
                <a href={`/services/${service.slug}/${s.slug}/`} class="rounded-full border border-gray-200 px-4 py-2 text-sm hover:border-primary hover:text-primary transition-colors">
                  {s.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside>
          <div class="sticky top-28 space-y-6">
            <div class="rounded-xl bg-primary p-6 text-white">
              <h3 class="text-xl font-bold">Need Help Now?</h3>
              <p class="mt-2 text-blue-100">Available 24/7 for emergencies</p>
              <a href={brand.phoneHref} class="btn-cta mt-4 w-full text-center block">{brand.phone}</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <LeadForm sourcePage={`/services/${service.slug}/${subService.slug}/`} preselectedService={service.slug} />
</BaseLayout>
