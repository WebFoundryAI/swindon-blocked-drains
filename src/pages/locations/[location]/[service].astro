---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import LeadForm from '../../../components/LeadForm.astro';
import { brand } from '../../../config/brand';
import { services } from '../../../config/services';
import { locations } from '../../../config/locations';
import { serviceInLocationTitle, serviceInLocationDescription } from '../../../config/seo';
import contentData from '../../../data/ai-content.json';
const content = contentData as Record<string, string>;

export function getStaticPaths() {
  return locations.flatMap(l =>
    services.map(s => ({
      params: { location: l.slug, service: s.slug },
      props: { location: l, service: s },
    }))
  );
}

const { location, service } = Astro.props;
const pageContent = content[`serviceInLocation:${location.slug}:${service.slug}`] || '';
const breadcrumbs = [
  { name: 'Areas We Cover', url: '/locations/' },
  { name: location.name, url: `/locations/${location.slug}/` },
  { name: service.name, url: `/locations/${location.slug}/${service.slug}/` },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.name} in ${location.name}`,
  description: `Professional ${service.name.toLowerCase()} services in ${location.name}.`,
  provider: {
    '@type': 'Plumber',
    name: brand.name,
    telephone: brand.phone,
  },
  areaServed: {
    '@type': 'Place',
    name: location.name,
    geo: { '@type': 'GeoCoordinates', latitude: location.lat, longitude: location.lng },
  },
};
---

<BaseLayout
  title={serviceInLocationTitle(service, location)}
  description={serviceInLocationDescription(service, location)}
  breadcrumbs={breadcrumbs}
  schemas={[serviceSchema]}
>
  <Breadcrumbs items={breadcrumbs} />
  <Hero title={`${service.name} in ${location.name}`} subtitle={service.description} compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid gap-12 lg:grid-cols-3">
        <div class="lg:col-span-2">
          {pageContent && (
            <div class="prose prose-lg max-w-none text-gray-700">
              <Fragment set:html={pageContent} />
            </div>
          )}

          <!-- Sub-services in this location -->
          {service.subServices.length > 0 && (
            <div class="mt-12">
              <h2 class="text-2xl font-bold text-accent">{service.name} Services in {location.name}</h2>
              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {service.subServices.map(sub => (
                  <a href={`/locations/${location.slug}/${service.slug}/${sub.slug}/`} class="group rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-primary hover:shadow-md">
                    <h3 class="font-semibold text-accent group-hover:text-primary transition-colors">{sub.name}</h3>
                    <p class="mt-1 text-sm text-gray-500">in {location.name}</p>
                    <span class="mt-2 inline-flex items-center text-sm text-primary">
                      Learn more
                      <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Other services in this location -->
          <div class="mt-12">
            <h2 class="text-2xl font-bold text-accent">Other Services in {location.name}</h2>
            <div class="mt-4 flex flex-wrap gap-3">
              {services.filter(s => s.slug !== service.slug).map(s => (
                <a href={`/locations/${location.slug}/${s.slug}/`} class="rounded-full border border-gray-200 px-4 py-2 text-sm hover:border-primary hover:text-primary transition-colors">
                  {s.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside>
          <div class="sticky top-28 space-y-6">
            <div class="rounded-xl bg-primary p-6 text-white">
              <h3 class="text-xl font-bold">Need Help in {location.name}?</h3>
              <p class="mt-2 text-blue-100">Available 24/7 for emergencies</p>
              <a href={brand.phoneHref} class="btn-cta mt-4 w-full text-center block">{brand.phone}</a>
            </div>
            <div class="rounded-xl border border-gray-200 p-6">
              <h3 class="font-semibold text-accent">{service.name} in Other Areas</h3>
              <ul class="mt-3 space-y-2">
                {locations.filter(l => l.slug !== location.slug).map(l => (
                  <li>
                    <a href={`/locations/${l.slug}/${service.slug}/`} class="text-sm text-gray-600 hover:text-primary transition-colors">
                      {service.name} in {l.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <LeadForm sourcePage={`/locations/${location.slug}/${service.slug}/`} preselectedService={service.slug} preselectedLocation={location.slug} />
</BaseLayout>
