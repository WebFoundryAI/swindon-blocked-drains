---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBadges from '../components/TrustBadges.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Guarantees from '../components/Guarantees.astro';
import CoverageArea from '../components/CoverageArea.astro';
import LeadForm from '../components/LeadForm.astro';
import PopularLinks from '../components/PopularLinks.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { brand } from '../config/brand';
import { services } from '../config/services';
import { homeTitle, homeDescription } from '../config/seo';
import contentData from '../data/ai-content.json';
const content = contentData as Record<string, string>;

const faqs = [
  { question: 'How quickly can you respond to an emergency?', answer: 'We aim to be with you within 1 hour for emergency call-outs across Swindon and surrounding areas. Our engineers are available 24 hours a day, 7 days a week.' },
  { question: 'Do you charge a call-out fee?', answer: 'No, we do not charge a call-out fee. You only pay for the work carried out. We provide a clear quote before starting any job.' },
  { question: 'Are your drainage engineers insured?', answer: 'Yes, all our engineers are fully insured and trained to the highest industry standards. You can have complete peace of mind when we work on your property.' },
  { question: 'What areas do you cover?', answer: 'We cover Swindon and the surrounding Wiltshire area, including Royal Wootton Bassett, Highworth, Purton, Cricklade, and Wroughton.' },
  { question: 'What payment methods do you accept?', answer: 'We accept cash, bank transfer, and all major credit and debit cards for your convenience.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<BaseLayout title={homeTitle()} description={homeDescription()} schemas={[faqSchema]}>
  <Hero
    title="Drain Unblocking & Blocked Drains in Swindon"
    subtitle="24/7 emergency drain unblocking, CCTV surveys, jetting & repairs. No call-out charge. Local, fully insured engineers."
  />

  <TrustBadges />

  <!-- Intro Content -->
  <section class="section-padding">
    <div class="container-narrow mx-auto max-w-3xl">
      <div class="prose prose-lg mx-auto text-gray-700">
        <Fragment set:html={content['home:intro'] || ''} />
      </div>
    </div>
  </section>

  <!-- Common Problems -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow mx-auto max-w-3xl">
      <h2 class="text-center text-3xl font-bold text-accent">Common Drain Problems We Fix in Swindon</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-gray-600">Whatever drain issue you're facing, our local Swindon engineers have the tools and experience to fix it fast.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <a href="/services/blocked-drains/blocked-sink/" class="rounded-lg border border-gray-200 bg-white p-4 hover:border-primary transition-colors group">
          <h3 class="font-semibold text-accent group-hover:text-primary">Blocked Sink</h3>
          <p class="mt-1 text-sm text-gray-600">Kitchen and bathroom sinks cleared quickly, including grease and soap build-up.</p>
        </a>
        <a href="/services/blocked-drains/blocked-toilet/" class="rounded-lg border border-gray-200 bg-white p-4 hover:border-primary transition-colors group">
          <h3 class="font-semibold text-accent group-hover:text-primary">Blocked Toilet</h3>
          <p class="mt-1 text-sm text-gray-600">Toilet blockages resolved same day with minimal disruption.</p>
        </a>
        <a href="/services/blocked-drains/blocked-bath/" class="rounded-lg border border-gray-200 bg-white p-4 hover:border-primary transition-colors group">
          <h3 class="font-semibold text-accent group-hover:text-primary">Blocked Bath &amp; Shower</h3>
          <p class="mt-1 text-sm text-gray-600">Hair, soap and limescale blockages cleared from bath and shower drains.</p>
        </a>
        <a href="/services/drain-unblocking/external-drain-unblocking/" class="rounded-lg border border-gray-200 bg-white p-4 hover:border-primary transition-colors group">
          <h3 class="font-semibold text-accent group-hover:text-primary">Blocked Outside Drain</h3>
          <p class="mt-1 text-sm text-gray-600">External drains, gullies and manhole blockages cleared using high-pressure jetting.</p>
        </a>
        <a href="/services/drain-jetting/" class="rounded-lg border border-gray-200 bg-white p-4 hover:border-primary transition-colors group">
          <h3 class="font-semibold text-accent group-hover:text-primary">Slow Drainage</h3>
          <p class="mt-1 text-sm text-gray-600">Slow-draining sinks, baths and showers diagnosed and fixed with professional jetting.</p>
        </a>
        <a href="/services/emergency-drain-services/" class="rounded-lg border border-gray-200 bg-white p-4 hover:border-primary transition-colors group">
          <h3 class="font-semibold text-accent group-hover:text-primary">Emergency Same-Day Call-Out</h3>
          <p class="mt-1 text-sm text-gray-600">24/7 emergency response for flooding, sewage issues and urgent drain problems.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section-padding">
    <div class="container-narrow mx-auto max-w-3xl">
      <h2 class="text-center text-3xl font-bold text-accent">Drain Unblocking Costs in Swindon</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-gray-600">Transparent, honest pricing with no hidden surprises.</p>
      <div class="mt-8 rounded-xl border border-gray-200 bg-white p-6 lg:p-8">
        <ul class="space-y-3 text-gray-700">
          <li class="flex items-start gap-3">
            <span class="mt-1 text-primary font-bold">&#10003;</span>
            <span><strong>No call-out fee</strong> &mdash; you only pay for the work carried out.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 text-primary font-bold">&#10003;</span>
            <span><strong>Fixed pricing</strong> &mdash; we provide a clear quote before starting any job.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 text-primary font-bold">&#10003;</span>
            <span><strong>No hidden extras</strong> &mdash; the price we quote is the price you pay.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 text-primary font-bold">&#10003;</span>
            <span><strong>Satisfaction guarantee</strong> &mdash; if the problem returns, we come back free of charge.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 text-primary font-bold">&#10003;</span>
            <span><strong>All payment methods accepted</strong> &mdash; cash, card or bank transfer.</span>
          </li>
        </ul>
        <p class="mt-6 text-sm text-gray-500">Every job is different, so we assess the issue on site and provide an exact quote before starting. Call <a href={brand.phoneHref} class="text-primary font-semibold hover:underline">{brand.phone}</a> for a free, no-obligation estimate.</p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow mx-auto">
      <h2 class="text-center text-3xl font-bold text-accent">Our Drain Services</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-gray-600">From emergency blockages to planned CCTV surveys, we handle every drainage challenge.</p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map(s => <ServiceCard service={s} />)}
      </div>
    </div>
  </section>

  <Guarantees />

  <CoverageArea />

  <!-- FAQ -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow mx-auto max-w-3xl">
      <h2 class="text-center text-3xl font-bold text-accent">Frequently Asked Questions</h2>
      <div class="mt-8">
        <FAQAccordion faqs={faqs} />
      </div>
    </div>
  </section>

  <PopularLinks />

  <LeadForm sourcePage="/" />
</BaseLayout>
