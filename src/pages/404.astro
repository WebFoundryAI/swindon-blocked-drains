---
import BaseLayout from '../layouts/BaseLayout.astro';
import { brand } from '../config/brand';

const title = '404 - Page Not Found';
const description = 'The page you are looking for does not exist. Return to our homepage or contact us.';
---

<BaseLayout title={title} description={description}>
  <main id="main-content" class="section-padding bg-gray-50">
    <div class="container-narrow mx-auto px-4">
      <!-- Error Message -->
      <div class="mb-12 text-center">
        <h1 class="mb-4 text-5xl font-bold text-primary lg:text-6xl">404</h1>
        <h2 class="mb-4 text-2xl font-bold text-gray-900 lg:text-3xl">Page Not Found</h2>
        <p class="mb-8 text-lg text-gray-600">
          Sorry, we couldn't find the page you're looking for. It may have been moved or deleted.
        </p>
      </div>

      <!-- Quick Links Grid -->
      <div class="mb-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Services Link -->
        <a href="/services/" class="group flex flex-col items-center gap-3 rounded-lg border border-gray-200 bg-white p-6 transition hover:border-primary hover:bg-blue-50">
          <span class="text-3xl">🔧</span>
          <h3 class="font-bold text-gray-900 group-hover:text-primary">Our Services</h3>
          <p class="text-center text-sm text-gray-600">Explore our drainage solutions</p>
        </a>

        <!-- Areas Link -->
        <a href="/locations/" class="group flex flex-col items-center gap-3 rounded-lg border border-gray-200 bg-white p-6 transition hover:border-primary hover:bg-blue-50">
          <span class="text-3xl">📍</span>
          <h3 class="font-bold text-gray-900 group-hover:text-primary">Service Areas</h3>
          <p class="text-center text-sm text-gray-600">Find coverage in your area</p>
        </a>

        <!-- Contact Link -->
        <a href="/contact/" class="group flex flex-col items-center gap-3 rounded-lg border border-gray-200 bg-white p-6 transition hover:border-primary hover:bg-blue-50">
          <span class="text-3xl">📞</span>
          <h3 class="font-bold text-gray-900 group-hover:text-primary">Contact Us</h3>
          <p class="text-center text-sm text-gray-600">Get in touch for a free quote</p>
        </a>

        <!-- FAQ Link -->
        <a href="/faqs/" class="group flex flex-col items-center gap-3 rounded-lg border border-gray-200 bg-white p-6 transition hover:border-primary hover:bg-blue-50">
          <span class="text-3xl">❓</span>
          <h3 class="font-bold text-gray-900 group-hover:text-primary">FAQs</h3>
          <p class="text-center text-sm text-gray-600">Common questions answered</p>
        </a>
      </div>

      <!-- CTA Section -->
      <div class="rounded-lg bg-primary px-6 py-12 text-center text-white sm:px-12">
        <h3 class="mb-4 text-2xl font-bold">Need Urgent Help?</h3>
        <p class="mb-6 text-lg text-blue-100">
          Call us 24/7 for emergency drain services in Swindon and surrounding areas
        </p>
        <div class="flex flex-col justify-center gap-4 sm:flex-row">
          <a href={brand.phoneHref} class="btn-cta inline-flex items-center gap-2 bg-white text-primary hover:bg-gray-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            Call {brand.phone}
          </a>
          <a href="/" class="btn-primary border border-white bg-transparent text-white hover:bg-white/10">
            Go Back Home
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
