---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BRAND } from '../../data/brand';
import { BLOG_POSTS, getRecentPosts, type BlogPost } from '../../data/blog';
import { getPublishedPosts, getPostBySlug, type CMSBlogPost } from '../../lib/blog-api';
import { serializeLexical, lexicalToPlainText } from '../../lib/lexical-html';
import { getBreadcrumbSchema, getBlogArticleSchema, getBaseBusinessSchema, serializeSchema } from '../../utils/schema';

export async function getStaticPaths() {
  // Local posts
  const localPaths = BLOG_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post, source: 'local' as const }
  }));

  // CMS posts
  const cmsResponse = await getPublishedPosts(500);
  const localSlugs = new Set(BLOG_POSTS.map((p) => p.slug));
  const cmsPaths = cmsResponse.docs
    .filter((post) => !localSlugs.has(post.slug))
    .map((post) => ({
      params: { slug: post.slug },
      props: { post, source: 'cms' as const }
    }));

  return [...localPaths, ...cmsPaths];
}

const { post, source } = Astro.props;

// Normalize post data
const isCMS = source === 'cms';
const postTitle = post.title;
const postSlug = post.slug;
const postAuthor = isCMS
  ? ((post as CMSBlogPost).author || (post as CMSBlogPost).site?.defaultAuthor || 'Team')
  : (post as BlogPost).author;
const postDate = isCMS
  ? ((post as CMSBlogPost).publishDate || new Date().toISOString())
  : (post as BlogPost).publishDate;
const postCategory = isCMS
  ? ((post as CMSBlogPost).categories?.[0]?.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()) || 'Blog')
  : (post as BlogPost).category;
const postTags = isCMS
  ? ((post as CMSBlogPost).categories || [])
  : (post as BlogPost).tags;
const postExcerpt = isCMS
  ? ((post as CMSBlogPost).excerpt || lexicalToPlainText((post as CMSBlogPost).content).slice(0, 200))
  : (post as BlogPost).excerpt;
const postMetaTitle = isCMS
  ? ((post as CMSBlogPost).seo?.metaTitle || postTitle)
  : (post as BlogPost).metaTitle;
const postMetaDescription = isCMS
  ? ((post as CMSBlogPost).seo?.metaDescription || postExcerpt)
  : (post as BlogPost).metaDescription;
const postReadingTime = isCMS
  ? Math.max(1, Math.ceil(lexicalToPlainText((post as CMSBlogPost).content).split(/\s+/).length / 200))
  : (post as BlogPost).readingTime;
const postSchemaType = isCMS ? ((post as CMSBlogPost).schemaType || 'BlogPosting') : 'BlogPosting';

// Get HTML content
let contentHtml: string;
if (isCMS) {
  contentHtml = serializeLexical((post as CMSBlogPost).content);
} else {
  contentHtml = formatContent((post as BlogPost).content);
}

// Featured image
const featuredImage = isCMS ? (post as CMSBlogPost).featuredImage : undefined;

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog/" },
  { name: postTitle, url: `/blog/${postSlug}/` }
]);

const articleSchemaData = isCMS ? {
  slug: postSlug,
  title: postTitle,
  metaTitle: postMetaTitle,
  metaDescription: postMetaDescription,
  excerpt: postExcerpt,
  content: '',
  author: postAuthor,
  publishDate: postDate,
  category: postCategory,
  tags: postTags,
  readingTime: postReadingTime,
} : post;

const articleSchema = getBlogArticleSchema(articleSchemaData as BlogPost);
const businessSchema = getBaseBusinessSchema();

const recentPosts = getRecentPosts(3).filter(p => p.slug !== postSlug).slice(0, 3);

function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

// Convert markdown-style headings and paragraphs to HTML (for local posts)
function formatContent(content: string): string {
  return content
    .split('\n\n')
    .map(paragraph => {
      if (paragraph.startsWith('## ')) {
        return `<h2 class="text-2xl font-bold mt-8 mb-4">${paragraph.replace('## ', '')}</h2>`;
      }
      if (paragraph.startsWith('### ')) {
        return `<h3 class="text-xl font-semibold mt-6 mb-3">${paragraph.replace('### ', '')}</h3>`;
      }
      if (paragraph.includes('\n- ')) {
        const items = paragraph.split('\n- ').filter(Boolean);
        const listItems = items.map(item => `<li class="ml-4">${item.replace(/^\- /, '')}</li>`).join('');
        return `<ul class="list-disc pl-6 mb-4 space-y-2">${listItems}</ul>`;
      }
      if (paragraph.match(/^\d\. /)) {
        const items = paragraph.split('\n').filter(Boolean);
        const listItems = items.map(item => `<li class="ml-4">${item.replace(/^\d\. /, '')}</li>`).join('');
        return `<ol class="list-decimal pl-6 mb-4 space-y-2">${listItems}</ol>`;
      }
      return `<p class="text-muted-foreground mb-4 leading-relaxed">${paragraph}</p>`;
    })
    .join('')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-primary hover:underline font-medium">$1</a>');
}
---

<BaseLayout
  title={postMetaTitle}
  description={postMetaDescription}
  canonical={`/blog/${postSlug}/`}
  schema={[businessSchema, articleSchema]}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Featured Image or Hero -->
  {featuredImage?.url ? (
    <section class="relative">
      <img src={featuredImage.url} alt={featuredImage.alt} class="w-full h-64 md:h-96 object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end">
        <div class="container-narrow px-4 pb-8 text-white">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-sm font-medium bg-white/20 px-3 py-1 rounded-full">{postCategory}</span>
            <span class="text-sm text-white/80">{postReadingTime} min read</span>
          </div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{postTitle}</h1>
          <div class="flex items-center gap-4 text-white/80 text-sm">
            <span>By {postAuthor}</span>
            <span>&middot;</span>
            <time datetime={postDate}>{formatDate(postDate)}</time>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="hero-section">
      <div class="hero-overlay py-16 md:py-20">
        <div class="container-narrow px-4 text-center text-white">
          <div class="flex items-center justify-center gap-2 mb-4">
            <span class="text-sm font-medium bg-white/20 px-3 py-1 rounded-full">{postCategory}</span>
            <span class="text-sm text-white/80">{postReadingTime} min read</span>
          </div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{postTitle}</h1>
          <div class="flex items-center justify-center gap-4 text-white/80 text-sm">
            <span>By {postAuthor}</span>
            <span>&middot;</span>
            <time datetime={postDate}>{formatDate(postDate)}</time>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Breadcrumbs -->
  <nav class="bg-muted/50 border-b border-border" aria-label="Breadcrumb">
    <div class="container-narrow px-4 py-3">
      <ol class="flex items-center gap-2 text-sm text-muted-foreground">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li><span class="mx-2">/</span></li>
        <li><a href="/blog/" class="hover:text-primary transition-colors">Blog</a></li>
        <li><span class="mx-2">/</span></li>
        <li class="text-foreground font-medium truncate max-w-[200px]">{postTitle}</li>
      </ol>
    </div>
  </nav>

  <!-- Article Content -->
  <article class="section-padding">
    <div class="container-narrow px-4">
      <div class="prose prose-lg max-w-none" set:html={contentHtml} />

      <!-- Tags -->
      <div class="mt-10 pt-6 border-t border-border">
        <div class="flex flex-wrap gap-2">
          {postTags.map((tag: string) => (
            <span class="text-sm bg-muted text-muted-foreground px-3 py-1 rounded-full">
              #{tag.replace(/\s+/g, '')}
            </span>
          ))}
        </div>
      </div>
    </div>
  </article>

  <!-- Related Posts -->
  {recentPosts.length > 0 && (
    <section class="section-padding bg-muted/50">
      <div class="container-wide px-4">
        <h2 class="text-2xl font-bold mb-8 text-center">More Articles</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {recentPosts.map((relatedPost) => (
            <article class="bg-white border border-border rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
              <div class="p-5">
                <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded">
                  {relatedPost.category}
                </span>
                <h3 class="text-lg font-bold mt-3 mb-2 line-clamp-2">
                  <a href={`/blog/${relatedPost.slug}/`} class="hover:text-primary transition-colors">
                    {relatedPost.title}
                  </a>
                </h3>
                <p class="text-muted-foreground text-sm line-clamp-2">
                  {relatedPost.excerpt}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Need Professional Help?</h2>
      <p class="text-xl text-primary-foreground/90 mb-8 max-w-2xl mx-auto">
        Our expert drainage team is available 24/7 across Swindon and surrounding Wiltshire areas.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`tel:${BRAND.phone}`} class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg">
          Call {BRAND.phoneFormatted}
        </a>
        <a href="/contact/" class="border-2 border-white text-white font-semibold px-8 py-4 rounded-lg hover:bg-white/10 transition-all text-lg">
          Get a Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
